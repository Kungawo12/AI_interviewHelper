DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_interview_helper?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ai_interview_helper?schema=public"

# PRIMARY voice — Google Cloud TTS (1,000,000 chars/month FREE forever)
# Setup: console.cloud.google.com → new project → Enable "Cloud Text-to-Speech API" → Credentials → Create API Key
GOOGLE_TTS_API_KEY="your-google-tts-api-key"

# SECONDARY voice — ElevenLabs (10,000 chars/month free, best quality)
# Sign up at https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# TERTIARY fallback — OpenAI TTS
OPENAI_API_KEY="your-openai-api-key"
